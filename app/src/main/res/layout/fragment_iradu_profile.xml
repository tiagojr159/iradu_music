<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ceu_estrelado"
    android:fillViewport="true"
    tools:context=".fragments.IraduProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/iradu_profile_header_background"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="22dp">

            <ImageView
                android:id="@+id/iradu_profile_photo"
                android:layout_width="148dp"
                android:layout_height="148dp"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:background="@drawable/iradu_profile_photo_background"
                android:contentDescription="@string/iradu_profile_tab_title"
                android:padding="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/iradu_profile_photo" />

            <org.schabi.newpipe.views.NewPipeTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/iradu_profile_highlight"
                android:textAllCaps="false"
                android:textColor="#00F5FF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <View
                android:layout_width="96dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/iradu_profile_accent_line" />

            <org.schabi.newpipe.views.NewPipeTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/iradu_profile_role"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <org.schabi.newpipe.views.NewPipeTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:lineSpacingExtra="5dp"
            android:text="@string/iradu_profile_about"
            android:textColor="#E8EEF7"
            android:textSize="16sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
